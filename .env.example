# Truv API credentials (get from app.truv.com)
API_CLIENT_ID=your_truv_client_id
API_SECRET=your_truv_secret

# ngrok tunnel URL (run: ngrok http 3000)
NGROK_URL=https://your-domain.ngrok-free.dev

# BSS simulation credentials (dev defaults)
BSS_CLIENT_ID=bss_wc_001
BSS_ACCESS_SECRET=bss_secret_dev
BSS_SIGNING_SECRET=bss_signing_dev

# Server port
PORT=3000
